# Credenciales de las fuentes de datos. Copia este fichero a `.env` y rellena.
# `.env` esta en .gitignore: NUNCA se sube al repo.

# OpenCelliD  -> https://opencellid.org  (registro gratis, API key empieza por pk.)
OCID_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WiGLE  -> https://wigle.net/account  (usa "Encoded for use" o API Name:API Token)
WIGLE_USER=AIDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WIGLE_PASS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NASA Earthdata (para CDDIS)  -> https://urs.earthdata.nasa.gov  (registro gratis)
EARTHDATA_USER=tu_usuario
EARTHDATA_PASS=tu_password

# API: si se define, exige header X-API-Key con este valor. Vacío = abierta (solo localhost).
API_KEY=

# MariaDB: contraseñas (déjalas por defecto en local; cámbialas si despliegas).
DB_PASS=geo
DB_ROOT_PASS=root
